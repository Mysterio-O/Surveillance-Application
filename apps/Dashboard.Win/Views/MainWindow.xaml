<Window x:Class="Dashboard.Win.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SurveilWin" Height="600" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#1e1e2e">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#74c7ec"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89b4fa"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Login Panel -->
        <StackPanel x:Name="LoginPanel" Visibility="Visible"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
            <TextBlock Text="SurveilWin" FontSize="28" FontWeight="Bold"
                       Foreground="#89b4fa" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Employee Activity Tracking" FontSize="12"
                       Foreground="#a6adc8" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Border Background="#181825" CornerRadius="12" Padding="30">
                <StackPanel>
                    <TextBlock Text="Email" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailBox" Style="{StaticResource TextInputStyle}" Margin="0,0,0,16"/>

                    <TextBlock Text="Password" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordInputStyle}" Margin="0,0,0,24"/>

                    <TextBlock x:Name="LoginErrorText" Foreground="#f38ba8" FontSize="11"
                               Visibility="Collapsed" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Button x:Name="LoginButton" Content="Sign In" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch" Click="LoginButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Shift Panel -->
        <StackPanel x:Name="ShiftPanel" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
            <Border Background="#181825" CornerRadius="12" Padding="30">
                <StackPanel>
                    <TextBlock Text="Ready to Start" FontSize="20" FontWeight="SemiBold"
                               Foreground="#cdd6f4" Margin="0,0,0,4"/>
                    <TextBlock x:Name="UserNameText" FontSize="12"
                               Foreground="#a6adc8" Margin="0,0,0,30"/>

                    <TextBlock x:Name="ShiftStatusText" FontSize="12"
                               Foreground="#a6adc8" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <Button x:Name="StartShiftButton" Content="Start Shift" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch" Click="StartShiftButton_Click" Margin="0,0,0,12"/>

                    <Button x:Name="LogoutButton" Content="Sign Out"
                            Background="#313244" Foreground="#cdd6f4" FontSize="12"
                            Padding="20,10" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" Click="LogoutButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Monitoring Panel -->
        <StackPanel x:Name="MonitoringPanel" Visibility="Collapsed"
                    VerticalAlignment="Top" Margin="30,30,30,0">
            <Border Background="#181825" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Shift Active" FontSize="12" Foreground="#a6adc8" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ShiftTimeText" FontSize="22" FontWeight="Bold" Foreground="#a6e3a1"/>
                    </StackPanel>
                    <Button x:Name="EndShiftButton" Grid.Column="1" Content="End Shift"
                            Background="#f38ba8" Foreground="#1e1e2e" FontSize="11" FontWeight="SemiBold"
                            Padding="16,8" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                            Click="EndShiftButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Border Background="#181825" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Status" FontSize="11" Foreground="#a6adc8" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Ellipse x:Name="AgentStatusDot" Width="10" Height="10" Fill="#a6e3a1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="AgentStatusText" Grid.Column="1" Foreground="#cdd6f4" FontSize="12" VerticalAlignment="Center" Text="Monitoring active"/>
                    </Grid>
                    <TextBlock x:Name="FrameCountText" Foreground="#a6adc8" FontSize="11" Text="Frames: 0"/>
                    <TextBlock x:Name="LastAppText" Foreground="#a6adc8" FontSize="11" Margin="0,4,0,0" Text="Last app: —"/>
                    <TextBlock x:Name="UploadStatusText" Foreground="#a6adc8" FontSize="11" Margin="0,4,0,0" Text="Upload: OK"/>
                </StackPanel>
            </Border>

            <Border Background="#181825" CornerRadius="12" Padding="24">
                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="ActivityLog" Background="Transparent" Foreground="#a6adc8"
                             FontSize="10" FontFamily="Consolas" IsReadOnly="True"
                             BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True"/>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>
