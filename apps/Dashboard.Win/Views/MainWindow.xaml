<Window x:Class="Dashboard.Win.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SurveilWin Dashboard" Height="700" Width="1100"
        Background="#1e1e2e" Foreground="#cdd6f4"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Base button style -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background"   Value="#89b4fa"/>
            <Setter Property="Foreground"   Value="#1e1e2e"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#74c7ec"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#45475a"/>
                    <Setter Property="Foreground" Value="#6c7086"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#f38ba8"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground"  Value="#a6adc8"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Value">
            <Setter Property="Foreground"  Value="#cdd6f4"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ================================================================
             TOP TOOLBAR
        ================================================================ -->
        <Border DockPanel.Dock="Top"
                Background="#181825" Padding="12,8">
            <DockPanel>
                <!-- Brand -->
                <TextBlock DockPanel.Dock="Left"
                           Text="SurveilWin"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#cba6f7"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"/>

                <!-- Action buttons -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="0,0,20,0">
                    <Button x:Name="BtnStart" Content="Start"
                            Style="{StaticResource PrimaryBtn}"
                            Margin="0,0,8,0" Click="Start_Click"/>
                    <Button x:Name="BtnPause" Content="Pause"
                            Style="{StaticResource DangerBtn}"
                            IsEnabled="False"
                            Margin="0,0,8,0" Click="Pause_Click"/>
                </StackPanel>

                <!-- Live status chips -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">

                    <!-- Running indicator -->
                    <Border x:Name="StatusDot"
                            Width="10" Height="10" CornerRadius="5"
                            Background="#45475a" Margin="0,0,6,0"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Idle"
                               Style="{StaticResource Value}"
                               Margin="0,0,20,0"/>

                    <!-- Active monitor -->
                    <TextBlock Text="Monitor:" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtMonitor" Text="—"
                               Style="{StaticResource Value}" Margin="0,0,20,0"/>

                    <!-- Active app -->
                    <TextBlock Text="App:" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtApp" Text="—"
                               Style="{StaticResource Value}" Margin="0,0,20,0"/>

                    <!-- FPS -->
                    <TextBlock Text="FPS:" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtFps" Text="1.0"
                               Style="{StaticResource Value}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ================================================================
             BOTTOM STATUS BAR
        ================================================================ -->
        <Border DockPanel.Dock="Bottom"
                Background="#11111b" Padding="12,4">
            <DockPanel>
                <TextBlock x:Name="TxtSession"
                           Text="Session: —"
                           Style="{StaticResource Label}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtFrameCount"
                           Text="Frames: 0"
                           Style="{StaticResource Label}"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- ================================================================
             MAIN CONTENT AREA
        ================================================================ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Activity summary list -->
            <DockPanel Grid.Column="0" Margin="8">
                <TextBlock DockPanel.Dock="Top"
                           Text="Activity Summaries"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#cba6f7" Margin="2,4,2,6"/>
                <ListBox x:Name="SummaryList"
                         Background="#181825"
                         Foreground="#cdd6f4"
                         BorderThickness="0"
                         FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderBrush" Value="#313244"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="#313244"/>

            <!-- Settings panel -->
            <StackPanel Grid.Column="2" Margin="8" Background="#181825">
                <TextBlock Text="Configuration"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#cba6f7" Margin="6,8,6,12"/>

                <!-- Thumbnails toggle -->
                <DockPanel Margin="6,4">
                    <TextBlock Text="Save thumbnails"
                               Style="{StaticResource Label}"
                               DockPanel.Dock="Left"/>
                    <CheckBox x:Name="ChkThumbnails"
                              DockPanel.Dock="Right"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Full trace toggle -->
                <DockPanel Margin="6,4">
                    <TextBlock Text="Full trace mode"
                               Style="{StaticResource Label}"
                               DockPanel.Dock="Left"/>
                    <CheckBox x:Name="ChkFullTrace"
                              DockPanel.Dock="Right"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <!-- OCR toggle -->
                <DockPanel Margin="6,4">
                    <TextBlock Text="Enable OCR"
                               Style="{StaticResource Label}"
                               DockPanel.Dock="Left"/>
                    <CheckBox x:Name="ChkOcr"
                              IsChecked="True"
                              DockPanel.Dock="Right"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <Separator Background="#313244" Margin="6,12"/>

                <!-- Connected monitors -->
                <TextBlock Text="Connected Monitors"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#a6e3a1" Margin="6,0,6,6"/>
                <ItemsControl x:Name="MonitorList" Margin="6,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Style="{StaticResource Label}"
                                       Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
