
<Window x:Class="Dashboard.Win.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surveil Dashboard" Height="600" Width="900">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="8">
            <Button Content="Start" Width="80" Margin="0,0,8,0" Click="Start_Click"/>
            <Button Content="Pause" Width="80" Margin="0,0,8,0" Click="Pause_Click"/>
            <TextBlock Text="Summaries" VerticalAlignment="Center"/>
        </StackPanel>
        <ListBox Name="SummaryList" Margin="8"/>
    </DockPanel>
</Window>
